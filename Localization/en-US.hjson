		Tiles.AsphaltMachine.MapEntry: Asphalt Machine

		NPCs: {
			AsphaltSlime: {
				DisplayName: Asphalt Slime
				Bestiary: These slimes seem to have absorbed the asphalt from the surrounding environment, and it gave them some new speedy abilities.
			}
		}

		Configs: {
			AsphaltModConfig: {
				DisplayName: Asphalt Mod Config

				BalanceChanges: {
					Label: Balance Changes
					Tooltip:
						'''
						Nerf the stats of most asphalt items to make them balanced with normal gameplay.
						Disable this option for the original overpowered stats from earlier Asphalt Mod versions.
						Note that newer items may not be affected by this option since they were already made with balance in mind.
						'''
				}
			}
		}
	}
